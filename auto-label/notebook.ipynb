   "id": "export-config",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Export final config\n",
    "import yaml\n",
    "\n",
    "final_config = {\n",
    "    'version': '1.0',\n",
    "    'scoring': config['scoring'],\n",
    "    'face_detection': config.get('face_detection', {}),\n",
    "    'story_detection': config.get('story_detection', {}),\n",
    "    'noise_categories': config.get('noise_categories', []),\n",
    "    'tag_categories': config.get('tag_categories', {}),\n",
    "}\n",
    "\n",
    "OUTPUT_FILE = 'config/scoring_rules.yaml'\n",
    "with open(OUTPUT_FILE, 'w', encoding='utf-8') as f:\n",
    "    yaml.dump(final_config, f, allow_unicode=True, default_flow_style=False)\n",
    "\n",
    "print(f'Exported to {OUTPUT_FILE}')\n",
    "\n",
    "# Show preview\n",
    "print('\\n--- Exported Config Preview ---')\n",
    "print(yaml.dump(final_config['scoring']['factors'], allow_unicode=True, default_flow_style=False)[:500])"
   ]
