   "cell_type": "markdown",
   "id": "intro",
   "metadata": {},
   "source": [
    "# Auto-Label Notebook — Rule Testing with 10 Albums\n",
    "**AMD OnClick AI / ROCm 6.4 compatible**\n",
    "\n",
    "Test different scoring factor combinations with 10 albums and iterate until consistent with human scores.\n",
    "\n",
    "| # | Section | What you do |\n",
    "|---|---------|-------------|\n",
    "| 0 | Setup | Install packages, load dataset |\n",
    "| 1 | Load Albums | Load 10 test albums |\n",
    "| 2 | Face Dedup | Test face detection & filtering |\n",
    "| 3 | Story Detect | Test story detection |\n",
    "| 4 | Score Testing | Test factor weights |\n",
    "| 5 | Compare | Compare with human scores |\n",
    "| 6 | Export | Export final `scoring_rules.yaml` |"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "setup",
   "metadata": {},
   "source": [
    "---\n",
    "## 0 · Setup — Install Dependencies\n",
    "\n",
    "> Run once per environment."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "pip-install",
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess, sys\n",
    "\n",
    "def pip(*args):\n",
    "    subprocess.check_call([sys.executable, '-m', 'pip', 'install', '-q', *args])\n",
    "\n",
    "# Torch — AMD ROCm 6.4\n",
    "pip('torch', 'torchvision', '--index-url', 'https://download.pytorch.org/whl/rocm6.4')\n",
    "\n",
    "# Core\n",
    "pip('transformers>=5.0.0', 'huggingface_hub>=1.9.0',\n",
    "    'datasets>=3.0.0', 'pandas>=2.0.0', 'Pillow>=10.0.0',\n",
    "    'numpy>=1.24.0', 'scikit-learn>=1.4.0')\n",
    "\n",
    "# Face detection\n",
    "pip('insightface>=0.7.3', 'onnxruntime>=1.17.0')\n",
    "\n",
    "# Story detection\n",
    "pip('imagehash>=4.3.0')\n",
    "\n",
    "# YAML\n",
    "pip('pyyaml>=6.0.0')\n",
    "\n",
    "print('Dependencies installed.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "hf-login",
   "metadata": {},
   "outputs": [],
   "source": [
    "# HF Login\n",
    "import os\n",
    "from getpass import getpass\n",
    "from huggingface_hub import login\n",
    "\n",
    "HF_TOKEN = getpass('HF Token: ')\n",
    "login(token=HF_TOKEN)\n",
    "os.environ['HF_TOKEN'] = HF_TOKEN\n",
    "print('Logged in to HuggingFace.')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "load-albums",
   "metadata": {},
   "source": [
    "---\n",
    "## 1 · Load 10 Test Albums\n",
    "\n",
    "Select 10 albums with diverse characteristics for testing."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "load-albums",
   "metadata": {},
   "outputs": [],
   "source": [
"# Load dataset - only sample 100 rows for testing\n",
     "from datasets import load_dataset\n",
     "from PIL import Image\n",
     "import pandas as pd\n",
     "\n",
     "DATASET_REPO = 'DownFlow/meizi'\n",
     "\n",
     "print('Loading first parquet (sample 100 rows)...')\n",
     "ds = load_dataset(DATASET_REPO, split='train', streaming=True)\n",
     "ds_sample = list(ds.take(100))\n",
     "print(f'Loaded: {len(ds_sample)} images')\n",
     "\n",
     "# Convert to dataframe\n",
     "df = pd.DataFrame([{\n",
     "    'image': x['image'],\n",
     "    'file_name': x['file_name'],\n",
     "    'album_id': x['album_id'],\n",
     "    'title': x['title'],\n",
     "    'model_name': x['model_name'],\n",
     "    'tags': x['tags'],\n",
     "    'album_score': x.get('album_score'),\n",
     "    'text_en': x.get('text_en', ''),\n",
     "    'text_cn': x.get('text_cn', ''),\n",
     "} for x in ds_sample])\n",
     "\n",
     "# Get unique albums with human scores\n",
     "scored_df = df[df['album_score'].notna()]\n",
     "scored_albums = scored_df.groupby('album_id')\n",
     "print(f'Albums with scores: {len(scored_albums)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "select-albums",
   "metadata": {},
   "outputs": [],
   "source": [
"# Select 10 diverse albums\n",
     "import random\n",
     "\n",
     "# Note: dataset images are shuffled, we'll use available albums\n",
     "album_groups = []\n",
     "for album_id, group in scored_albums:\n",
     "    if len(group) >= 10:  # Use what we have for testing\n",
     "        avg_score = group['album_score'].mean()\n",
     "        album_groups.append({\n",
     "            'album_id': album_id,\n",
    "            'count': len(group),\n",
    "            'avg_score': avg_score,\n",
    "            'sample': group.iloc[0]\n",
    "        })\n",
    "\n",
    "# Sort by score and select diverse set\n",
    "album_groups.sort(key=lambda x: x['avg_score'])\n",
    "\n",
    "# Select: 2 low (1-3), 4 mid (4-6), 4 high (7-9)\n",
    "test_albums = []\n",
    "test_albums.extend([a for a in album_groups if a['avg_score'] <= 3][:2])\n",
    "test_albums.extend([a for a in album_groups if 4 <= a['avg_score'] <= 6][:4])\n",
    "test_albums.extend([a for a in album_groups if a['avg_score'] >= 7][:4])\n",
    "\n",
    "print(f'Selected {len(test_albums)} test albums:')\n",
    "for i, a in enumerate(test_albums):\n",
    "    print(f\"  {i+1}. Album {a['album_id']}: {a['count']} images, avg_score={a['avg_score']:.1f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "face-dedup",
   "metadata": {},
   "source": [
    "---\n",
    "## 2 · Face Deduplication Test\n",
    "\n",
    "Test InsightFace detection and filtering on one album."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "face-test",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test face detection on one album\n",
    "from insightface.app import FaceAnalysis\n",
    "import numpy as np\n",
    "\n",
    "print('Loading InsightFace...')\n",
    "app = FaceAnalysis(name='buffalo_l', providers=['CPU', 'CUDAExecutionProvider'])\n",
    "app.prepare(ctx_id=0, det_size=(640, 640))\n",
    "\n",
    "# Test on first album\n",
    "test_album = test_albums[0]\n",
    "album_id = test_album['album_id']\n",
    "\n",
    "print(f'Testing on album {album_id}...')\n",
    "\n",
    "# Get images for this album\n",
    "album_images = ds.filter(lambda x: x['album_id'] == album_id)\n",
    "print(f'Found {len(album_images)} images')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "face-visualize",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize face detection\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "fig, axes = plt.subplots(2, 4, figsize=(12, 6))\n",
    "axes = axes.flatten()\n",
    "\n",
    "face_counts = []\n",
    "for idx, row in enumerate(album_images.select(range(8))):\n",
    "    img = row['image']\n",
    "    faces = app.get(np.array(img))\n",
    "    face_counts.append(len(faces))\n",
    "    \n",
    "    # Draw bounding boxes\n",
    "    import cv2\n",
    "    img_cv = cv2.cvtColor(np.array(img), cv2.COLOR_RGB2BGR)\n",
    "    for face in faces:\n",
    "        bbox = face.bbox.astype(int)\n",
    "        cv2.rectangle(img_cv, (bbox[0], bbox[1]), (bbox[2], bbox[3]), (0, 255, 0), 2)\n",
    "    \n",
    "    axes[idx].imshow(cv2.cvtColor(img_cv, cv2.COLOR_BGR2RGB))\n",
    "    axes[idx].set_title(f'Faces: {len(faces)}')\n",
    "    axes[idx].axis('off')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f'Face counts: {face_counts}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "story-detect",
   "metadata": {},
   "source": [
    "---\n",
    "## 3 · Story Detection Test\n",
    "\n",
    "Test story detection on albums with 30+ images."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "story-import",
   "metadata": {},
   "outputs": [],
   "source": [
    "from imagehash import phash\n",
    "import numpy as np\n",
    "from PIL import Image\n",
    "\n",
    "def compute_hist(img):\n",
    "    \"\"\"Compute color histogram.\"\"\"\n",
    "    hist = []\n",
    "    for i in range(3):\n",
    "        channel_hist = img.histogram()[i*256:(i+1)*256]\n",
    "        hist.extend(channel_hist)\n",
    "    hist = np.array(hist, dtype=float)\n",
    "    return hist / (hist.sum() + 1e-7)\n",
    "\n",
    "def cosine_sim(a, b):\n",
    "    return np.dot(a, b) / (np.linalg.norm(a) * np.linalg.norm(b) + 1e-7)\n",
    "\n",
    "print('Story detection helpers ready.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "story-test",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test story detection on first album\n",
    "test_album = test_albums[0]\n",
    "album_id = test_album['album_id']\n",
    "\n",
    "print(f'Testing story detection on album {album_id}...')\n",
    "\n",
    "images = list(album_images.take(30))\n",
    "histograms = [compute_hist(row['image']) for row in images]\n",
    "\n",
    "# Detect outfit changes\n",
    "outfit_changes = [0]\n",
    "for i in range(1, len(histograms)):\n",
    "    sim = cosine_sim(histograms[i-1], histograms[i])\n",
    "    if sim < 0.85:\n",
    "        outfit_changes.append(i)\n",
    "\n",
    "print(f'Outfit changes detected: {len(outfit_changes)}')\n",
    "print(f'Key frames: {outfit_changes}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "score-testing",
   "metadata": {},
   "source": [
    "---\n",
    "## 4 · Score Factor Testing\n",
    "\n",
    "Test different weight combinations against human scores."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "config-setup",
   "metadata": {},
   "outputs": [],
   "source": [
    "import yaml\n",
    "\n",
    "# Load default config\n",
    "with open('config/default.yaml', 'r') as f:\n",
    "    config = yaml.safe_load(f)\n",
    "\n",
    "print('Default config loaded:')\n",
    "for factor, info in config['scoring']['factors'].items():\n",
    "    print(f\"  {factor}: weight={info['weight']}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "test-weights",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test different weight combinations\n",
    "weight_experiments = [\n",
    "    # Test 1: Default (from config)\n",
    "    {'face': 0.30, 'body': 0.15, 'pose': 0.15, 'clothing': 0.10, 'background': 0.10, 'lighting': 0.10, 'composition': 0.10},\n",
    "    \n",
    "    # Test 2: Face-focused\n",
    "    {'face': 0.50, 'body': 0.10, 'pose': 0.10, 'clothing': 0.10, 'background': 0.05, 'lighting': 0.10, 'composition': 0.05},\n",
    "    \n",
    "    # Test 3: Equal weights\n",
    "    {'face': 0.14, 'body': 0.14, 'pose': 0.14, 'clothing': 0.14, 'background': 0.14, 'lighting': 0.14, 'composition': 0.14},\n",
    "    \n",
    "    # Test 4: Quality-focused (lighting + composition)\n",
    "    {'face': 0.20, 'body': 0.10, 'pose': 0.10, 'clothing': 0.10, 'background': 0.15, 'lighting': 0.20, 'composition': 0.15},\n",
    "]\n",
    "\n",
    "for i, weights in enumerate(weight_experiments):\n",
    "    print(f\"Test {i+1}: face={weights['face']}, composition={weights['composition']}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "compare-human",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compare AI scores with human scores\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "results = []\n",
    "for album_data in test_albums:\n",
    "    album_id = album_data['album_id']\n",
    "    human_score = album_data['avg_score']\n",
    "    \n",
    "    # TODO: Call vLLM to get actual scores\n",
    "    # For now, simulate\n",
    "    ai_score = human_score + np.random.uniform(-0.5, 0.5)\n",
    "    \n",
    "    results.append({\n",
    "        'album_id': album_id,\n",
    "        'human': human_score,\n",
    "        'ai': ai_score,\n",
    "    })\n",
    "\n",
    "# Plot comparison\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "x = range(len(results))\n",
    "labels = [r['album_id'] for r in results]\n",
    "human_scores = [r['human'] for r in results]\n",
    "ai_scores = [r['ai'] for r in results]\n",
    "\n",
    "ax.bar([i-0.2 for i in x], human_scores, 0.4, label='Human', alpha=0.7)\n",
    "ax.bar([i+0.2 for i in x], ai_scores, 0.4, label='AI', alpha=0.7)\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(labels, rotation=45)\n",
    "ax.set_ylabel('Score')\n",
    "ax.set_title('Human vs AI Score Comparison')\n",
    "ax.legend()\n",
    "ax.set_ylim(0, 10)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
